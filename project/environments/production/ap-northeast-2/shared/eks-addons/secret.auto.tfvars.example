# 이 파일을 secret.auto.tfvars로 복사하여 실제 값을 채우세요.
# secret.auto.tfvars는 .gitignore(*.tfvars)에 의해 Git 추적에서 제외됩니다.

operator_ip_cidr             = "x.x.x.x/32"  # 운영자 공인 IP (ArgoCD ALB 허용)
argocd_admin_password_bcrypt = "$2b$10$..."   # ArgoCD admin bcrypt 해시
# 해시 생성: python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
