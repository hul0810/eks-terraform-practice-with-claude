# Terraform 로컬 디렉토리 및 파일
.terraform/
# .terraform.lock.hcl 은 provider 버전 고정을 위해 git으로 관리한다

# 상태 파일 (원격 백엔드 사용 - 로컬 커밋 금지)
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# 환경 변수 파일 (민감 정보 포함 가능)
*.tfvars
!*.tfvars.example

# 플랜 파일
*.tfplan

# 크래시 로그
crash.log
crash.*.log

# OS 파일
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code 세션 상태 파일
.claude/.prd-changed
.claude/.prd-review-skipped.log

# Claude Code 에이전트 메모리 (계정별 IAM 사용자명·권한 등 민감 정보 포함 가능 — 로컬 전용 캐시)
.claude/agent-memory/

# infracost 가격 캐시 (자동 생성 바이너리 — 커밋 불필요)
.infracost/
